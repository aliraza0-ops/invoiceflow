# Get free key from: console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Your Gmail address
GMAIL_USER=your@gmail.com

# Get from: myaccount.google.com → Security → App Passwords
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Your business info (shown on every invoice)
BUSINESS_NAME=Your Business Name
BUSINESS_EMAIL=your@gmail.com
BUSINESS_PHONE=+92-300-0000000
BUSINESS_ADDRESS=Your City, Pakistan
BUSINESS_NTN=

# Pakistani payment methods (optional)
EASYPAISA_NUM=03XX-XXXXXXX
JAZZCASH_NUM=03XX-XXXXXXX

# Dashboard login password (set your own)
DASHBOARD_PASSWORD=yourpassword

# Any random string for session security
SECRET_KEY=any-random-string-here

# Webhook secret for Google Sheets integration
WEBHOOK_SECRET=invoiceflow2026
